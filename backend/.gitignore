.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# -----------------------------------------------------------------------------
# Testy i pokrycie kodu
# -----------------------------------------------------------------------------
/coverage
/.nyc_output
/test-results.xml
*.gc.log
package-lock.json

# -----------------------------------------------------------------------------
# Dane wrażliwe i bazy danych
# -----------------------------------------------------------------------------
# (Dodaj te, jeśli serwer przechowuje lokalne pliki DB lub uploady)
*.sqlite
*.sqlite3
/uploads/
/data/

# -----------------------------------------------------------------------------
# Pliki systemowe i edytorów
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
# Edytory i IDE
.vscode
.idea
*.sublime-project
*.sublime-workspace
/src/generated/prisma
