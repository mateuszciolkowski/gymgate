# -----------------------------------------------------------------------------
# Zależności i pakiety
# -----------------------------------------------------------------------------
/node_modules
/jspm_packages/
# Pnpm
/pnpm-lock.yaml
/pnpm-debug.log*
# Yarn
yarn-error.log
.pnp
.pnp.js
.pnp.cjs

# -----------------------------------------------------------------------------
# Pliki kompilacji i dystrybucji (TypeScript/Babel/WebAssembly)
# -----------------------------------------------------------------------------
# Oczekiwane katalogi wyjściowe po transpilacji
/dist
/build
/out

# Pliki TypeScript/Babel
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Logi i dane tymczasowe
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
lerna-debug.log*

# Pliki tymczasowe
*.tmp
*.bak
/temp

# -----------------------------------------------------------------------------
# Pliki środowiskowe (kluczowe dla serwera)
# -----------------------------------------------------------------------------
