DATABASE_URL="postgresql://user:password@host:5432/database_name"
DIRECT_URL="postgresql://user:password@host:5432/database_name"
JWT_SECRET="replace-with-a-strong-secret"
NODE_ENV=development
API_PORT=3000

# Tryb bazy danych: 'remote' (Supabase) lub 'local' (Docker PostgreSQL na localhost:5433)
# Zmień na 'local' żeby używać lokalnej bazy testowej z historią treningów
DB_ENV=remote
DATABASE_URL_LOCAL="postgresql://postgres:postgres@localhost:5433/gymgate_local"
DIRECT_URL_LOCAL="postgresql://postgres:postgres@localhost:5433/gymgate_local"  # używane przez: make local-migrate
