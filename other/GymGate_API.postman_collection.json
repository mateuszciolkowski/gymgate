      "name": "[01] Health check – API online",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('[01] API odpowiada na GET /', () => pm.response.to.have.status(200));",
        "pm.test('[01] Zawiera status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));",
        "pm.test('[01] Zawiera GymGate w message', () => pm.expect(pm.response.json().message).to.include('GymGate'));"
      ], "type": "text/javascript" }}],
      "request": { "method": "GET", "header": [],
        "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
      }
    },
    {
      "name": "[02] Health check – /health endpoint",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('[02] /health zwraca 200 OK', () => pm.response.to.have.status(200));",
        "pm.test('[02] Zawiera timestamp', () => { const j = pm.response.json(); pm.expect(j.status).to.eql('ok'); pm.expect(j.timestamp).to.be.a('string'); });"
      ], "type": "text/javascript" }}],
      "request": { "method": "GET", "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "[03] AUTH – Rejestracja nowego użytkownika",
      "event": [
        { "listen": "prerequest", "script": { "exec": [
          "const email = 'e2e_' + Date.now() + '@gymgate.pl';",
          "pm.collectionVariables.set('testEmail', email);",
          "pm.collectionVariables.set('authToken', '');",
          "console.log('Test email:', email);"
        ], "type": "text/javascript" }},
        { "listen": "test", "script": { "exec": [
          "pm.test('[03] Rejestracja zwraca 201 Created', () => pm.response.to.have.status(201));",
          "pm.test('[03] success=true', () => pm.expect(pm.response.json().success).to.be.true);",
          "pm.test('[03] Zawiera token JWT', () => {",
          "  const j = pm.response.json();",
          "  pm.expect(j.data.token).to.be.a('string').and.have.length.above(10);",
          "  pm.collectionVariables.set('authToken', j.data.token);",
          "});",
          "pm.test('[03] Zawiera dane użytkownika', () => {",
          "  const j = pm.response.json();",
          "  pm.expect(j.data.user.id).to.be.a('string');",
          "  pm.expect(j.data.user.email).to.eql(pm.collectionVariables.get('testEmail'));",
          "  pm.collectionVariables.set('userId', j.data.user.id);",
          "});"
        ], "type": "text/javascript" }}
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"e2eTestPass123\",\n  \"firstName\": \"E2E\",\n  \"lastName\": \"Tester\",\n  \"phone\": \"+48100200300\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
      }
    },
